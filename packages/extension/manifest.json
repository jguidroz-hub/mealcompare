{
  "manifest_version": 3,
  "name": "SkipTheFee — Save on Food Delivery",
  "description": "Compare prices across DoorDash, Uber Eats, Grubhub & direct ordering. Save $5-15 per order.",
  "version": "0.1.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.doordash.com/*",
    "https://www.ubereats.com/*",
    "https://www.grubhub.com/*",
    "https://*.toast.site/*",
    "https://order.toasttab.com/*",
    "https://skipthefee.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.doordash.com/*"],
      "js": ["content/doordash.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.ubereats.com/*"],
      "js": ["content/ubereats.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.grubhub.com/*"],
      "js": ["content/grubhub.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.toast.site/*", "https://order.toasttab.com/*"],
      "js": ["content/toast-scraper.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "chunks/*"],
      "matches": [
        "https://www.doordash.com/*",
        "https://www.ubereats.com/*",
        "https://www.grubhub.com/*",
        "https://*.toast.site/*",
        "https://order.toasttab.com/*"
      ]
    }
  ]
}
